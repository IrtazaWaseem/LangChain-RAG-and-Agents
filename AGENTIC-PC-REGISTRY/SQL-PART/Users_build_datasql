DROP TABLE USER_PC_BUILDS CASCADE CONSTRAINTS;

CREATE TABLE USER_PC_BUILDS (
    Build_ID NUMBER PRIMARY KEY,
    User_ID NUMBER NOT NULL,
    Build_Name VARCHAR2(100) NOT NULL,
    CPU_ID NUMBER NOT NULL,
    GPU_ID NUMBER NOT NULL,
    RAM_ID NUMBER NOT NULL,
    OS_ID NUMBER NOT NULL,
    SSD_ID NUMBER NOT NULL,
    Is_Primary VARCHAR2(1) NOT NULL,
    CONSTRAINT chk_is_primary CHECK (Is_Primary IN ('Y', 'N')),
    CONSTRAINT fk_build_user FOREIGN KEY (User_ID) REFERENCES USERS(User_ID) ON DELETE CASCADE,
    CONSTRAINT fk_build_cpu FOREIGN KEY (CPU_ID) REFERENCES CPUS(CPU_ID),
    CONSTRAINT fk_build_gpu FOREIGN KEY (GPU_ID) REFERENCES GPUS(GPU_ID),
    CONSTRAINT fk_build_ram FOREIGN KEY (RAM_ID) REFERENCES RAM_CONFIGURATIONS(RAM_ID),
    CONSTRAINT fk_build_os FOREIGN KEY (OS_ID) REFERENCES OPERATING_SYSTEMS(OS_ID),
    CONSTRAINT fk_build_ssd FOREIGN KEY (SSD_ID) REFERENCES SSDS(SSD_ID)
);

